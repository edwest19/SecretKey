using System;
using System.IO;

try
{
    // We are looking for a file that we know doesn't exist yet
    string fileName = "config.json";

    Console.WriteLine($"Checking for {fileName} in: {Environment.CurrentDirectory}");

    // This will "throw" an error if the file is missing
    string content = File.ReadAllText(fileName);

    Console.WriteLine("Success! File found.");
}
catch (FileNotFoundException)
{
    // This is the "Pop" you wanted
    Console.ForegroundColor = ConsoleColor.Red;
    Console.WriteLine("\nERROR: FILE NOT FOUND");
    Console.ResetColor();
    Console.WriteLine("The config.json is missing from the execution folder.");
}
catch (Exception ex)
{
    Console.WriteLine($"An unexpected error occurred: {ex.Message}");
}

Console.WriteLine("\nPress any key to exit...");
Console.ReadKey();