<Window
    x:Class="SecretKeyUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SecretKey Controller">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Padding="30" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel Spacing="18" VerticalAlignment="Top" MaxWidth="600" HorizontalAlignment="Left">
                <TextBlock Text="SecretKey Admin Console" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Manage configuration properties and execute the cryptographic state machine entirely offline." Foreground="Gray" Margin="0,0,0,10"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="Active Data Workspace Directory (Stores config.json)" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextControlHeaderForeground}"/>
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <TextBox x:Name="TxtWorkspacePath" IsReadOnly="True" PlaceholderText="Select workspace directory..."/>
                        <Button Content="Select Folder..." Grid.Column="1" Padding="12,6" Click="BtnBrowseWorkspace_Click"/>
                    </Grid>
                </StackPanel>

                <MenuFlyoutSeparator Margin="0,5"/>

                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="12" ColumnSpacing="10">
                    <TextBox x:Name="TxtInputPath" Grid.Row="0" Grid.Column="0" Header="Input Vault Path (.csv)" PlaceholderText="Select your 1Password export..."/>
                    <Button Content="Browse..." Grid.Row="0" Grid.Column="1" VerticalAlignment="Bottom" Padding="12,6" Click="BtnBrowseInput_Click"/>

                    <TextBox x:Name="TxtOutputPath" Grid.Row="1" Grid.Column="0" Header="Output Target Path (.csv)" PlaceholderText="Select where to save generated vault..."/>
                    <Button Content="Browse..." Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" Padding="12,6" Click="BtnBrowseOutput_Click"/>
                </Grid>

                <TextBox x:Name="TxtMask" Header="Global Password Pattern Mask" PlaceholderText="e.g., XxxxxNSxxxNN"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="Cryptographic Root Key Base" FontSize="12" FontWeight="Normal" Foreground="{ThemeResource TextControlHeaderForeground}"/>
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <TextBox x:Name="TxtRootKey" PlaceholderText="Enter master root key or generate a new one..."/>
                        <Button Content="Generate New Key" Grid.Column="1" Padding="12,6" Click="BtnGenerateRootKey_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4" Margin="0,10,0,10">
                    <TextBlock Text="Active Runtime Date Code" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextControlHeaderForeground}"/>
                    <TextBox x:Name="TxtDateCode" MaxLength="4" PlaceholderText="e.g., 2606" Width="150" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="10" Margin="0,5,0,5">
                    <Button x:Name="BtnSaveConfig" 
                            Content="Save Config" 
                            HorizontalAlignment="Stretch" Padding="14"
                            Click="BtnSaveConfig_Click"/>

                    <Button x:Name="BtnRunEngine" 
                            Content="Run SecretKey" 
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Padding="14"
                            Click="BtnRunEngine_Click"/>

                    <Button x:Name="BtnCloseApp" 
                            Content="Close Application" 
                            HorizontalAlignment="Stretch" Padding="14"
                            Click="BtnCloseApp_Click"/>
                </StackPanel>

                <InfoBar x:Name="StatusDisplay" IsOpen="True" Severity="Informational" Title="Status:" Message="Ready" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>